{
  "name": "tecnickcom/tc-lib-color",
  "description": "PHP library to manipulate various color representations",
  "type": "library",
  "homepage": "https://tcpdf.org",
  "license": "LGPL-3.0-or-later",
  "keywords": [
    "tc-lib-color",
    "color",
    "colors",
    "colour",
    "colours",
    "javascript",
    "web",
    "rgb",
    "rgba",
    "cmyk",
    "hsl",
    "hsla"
  ],
  "authors": [
    {
      "name": "Nicola Asuni",
      "email": "info@tecnick.com",
      "role": "lead"
    }
  ],
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/tecnickcom"
    }
  ],
  "require": {
    "php": ">=8.2",
    "ext-pcre": "*"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "require-dev": {
    "pdepend/pdepend": "^2.16",
    "phpunit/phpunit": "^13.1 || ^12.5 || ^11.5",
    "phpcompatibility/php-compatibility": "^10.0.0@dev"
  },
  "autoload": {
    "psr-4": {
      "Com\\Tecnick\\Color\\": "src"
    }
  },
  "autoload-dev": {
    "psr-4": { "Test\\": "test" }
  },
  "support": {
    "issues": "https://github.com/tecnickcom/tc-lib-color/issues",
    "source": "https://github.com/tecnickcom/tc-lib-color"
  },
  "scripts": {
    "test": "XDEBUG_MODE=coverage ./vendor/bin/phpunit --stderr test",
    "cs-check": "./vendor/bin/mago --config ./mago.src.toml lint src && ./vendor/bin/mago --config ./mago.test.toml lint test",
    "cs-fix": "./vendor/bin/mago fmt src test",
    "analyse": "./vendor/bin/mago --config ./mago.src.toml analyze src && ./vendor/bin/mago --config ./mago.test.toml analyze test"
  }
}
